{
  "$schema": "../scripts/manifest-schema.json",
  "bmad-type": "bmad-agent"{if-module},
  "bmad-module-name": "{ModuleDisplayName}",
  "bmad-module-code": "{module-code}"{/if-module}{if-autonomous},
  "bmad-activation-modes": ["interactive", "autonomous"],
  "bmad-autonomous-default": "{default-autonomous-task}"{/if-autonomous}{if-autonomous-tasks},
  "bmad-autonomous-tasks": [
{foreach-autonomous-task}    {
      "name": "{prompt-name}",
      "display-name": "{Display Name}",
      "description": "{Brief description}"
    }{sep-comma}
{/foreach-autonomous-task}
  ]
{/if-autonomous-tasks},
  "bmad-capabilities": [
{if-init}    {
      "name": "init",
      "menu-code": "IN",
      "display-name": "Onboarding",
      "description": "First-run setup",
      "type": "prompt",
      "phase": "init",
      "required": true
    },
{/if-init}{foreach-capability}    {
      "name": "{capability-name}",
      "menu-code": "{menu-code}",
      "display-name": "{Display Name}",
      "description": "{What this capability does and when to suggest it.}",
      "type": "{prompt|skill}",
      "phase": "on-demand",
      "required": false
    }{sep-comma}
{/foreach-capability}
  ]
}
